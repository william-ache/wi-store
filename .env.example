MEMCACHED_USERNAME=
MEMCACHED_PASSWORD=
MEMCACHED_PERSISTENT_ID=

REDIS_CLIENT=phpredis
REDIS_CLUSTER=redis
REDIS_PREFIX="${APP_NAME}-database-"
